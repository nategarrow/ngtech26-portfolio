    "@sanity/ui": "^3.1.11",
    "@sanity/vision": "^5.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "^5.8.1",
    "sanity-plugin-media": "^4.1.1",
    "styled-components": "^6.3.9",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.2.13",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
